# Telegram Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
TELEGRAM_ALERT_CHAT_ID=your_alert_chat_id_here

# PRODUCTION SETTINGS
SCAN_INTERVAL_SECONDS=30
MIN_5M_VOLUME_USD_NEW=300000
MAX_TOKEN_AGE_HOURS=2
MIN_STABILITY_CHECKS=2
MIN_5M_VOLUME_USD_ESTABLISHED=2000000
MIN_HOLDERS=50
MIN_MARKET_CAP_USD=100000
MAX_BUY_TAX=3
MAX_SELL_TAX=3
EXCLUDE_HONEYPOTS=true
DEDUP_TTL_HOURS=24
DEDUP_ALERT_MINUTES=10

# API Keys
DEXTOOLS_API_KEY=your_dextools_api_key_here
BSCSCAN_API_KEY=your_bscscan_api_key_here
BITQUERY_API_KEY=your_bitquery_api_key_here

# Krystal API (Optional)
KRYSTAL_API_BASE=https://cloud-api.krystal.app
KRYSTAL_API_KEY=your_krystal_api_key_here
KRYSTAL_CHAIN=bsc
KRYSTAL_DEX=pancakeswap

# Volume Filters
MAX_5M_VOLUME_USD=40000000
MIN_VOLUME_SKIP_HOLDERS=1000000
